rules_version = '2';

// CDFA Hub Firestore security rules.
//
// Access model: "shared-secret + authenticated".
//   - Any signed-in user who knows the shareId may read/write the project.
//   - shareId is an unguessable 8-char token generated by useFirebaseSync.
//   - This fits 1-2 trusted admins collaborating during a live meeting event.
//
// Deploy with:
//   npx firebase-tools deploy --only firestore:rules

service cloud.firestore {
  match /databases/{database}/documents {

    // Top-level project documents, keyed by shareId.
    match /projects/{shareId} {
      allow read, write: if request.auth != null;

      // Presence markers for active collaborators.
      // Users can see everyone present, but only write their own marker.
      match /presence/{userId} {
        allow read: if request.auth != null;
        allow write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
