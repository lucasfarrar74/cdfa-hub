# Firebase Configuration
# Get these values from Firebase Console -> Project Settings
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Team collaboration toggle.
# Leave unset or false for solo-dev mode (no login required, hardcoded user).
# Set to "true" only after Firestore rules are deployed and Firebase Console
# sign-in methods are enabled. See CLAUDE.md "Enabling collaboration" section.
VITE_ENABLE_AUTH=false

# Google OAuth 2.0 client ID (Web application).
# Only needed if you want the "Push to Google Sheets" export feature.
# Create it at https://console.cloud.google.com/apis/credentials for the
# meeting-scheduler-c045b project with Vercel prod as an authorized origin.
# See CLAUDE.md "Enabling Google Sheets export" section.
VITE_GOOGLE_OAUTH_CLIENT_ID=
